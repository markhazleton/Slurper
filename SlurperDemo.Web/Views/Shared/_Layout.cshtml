<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebSpark.Slurper</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/vendors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SlurperDemo.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-code-square text-primary"></i> WebSpark.Slurper
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Overview</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Demos
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="XmlDemo">
                                        <i class="bi bi-file-code me-2 text-primary"></i>XML Extraction
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="JSON" asp-action="Index">
                                        <i class="bi bi-braces me-2 text-success"></i>JSON Extraction
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="CsvDemo">
                                        <i class="bi bi-table me-2 text-info"></i>CSV Extraction
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="HtmlDemo">
                                        <i class="bi bi-filetype-html me-2 text-warning"></i>HTML Extraction
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="LegacyDemo">
                                        <i class="bi bi-archive me-2 text-secondary"></i>Legacy Static API
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="ApiDemo" asp-action="Index">
                                        <i class="bi bi-layers me-2 text-danger"></i>Multi-Format Demo
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="https://www.nuget.org/packages/WebSpark.Slurper" target="_blank" rel="noopener">
                                <i class="bi bi-box-seam me-1"></i>NuGet
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="https://github.com/MarkHazleton/Slurper" target="_blank" rel="noopener">
                                <i class="bi bi-github me-1"></i>GitHub
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-3">
            <div class="d-flex flex-wrap justify-content-between align-items-center">
                <span>&copy; @DateTime.Now.Year WebSpark.Slurper &mdash; MIT License</span>
                <span>
                    Built by <a href="https://markhazleton.com" class="text-decoration-none">Mark Hazleton</a> &middot;
                    <a href="https://makeboldsolutions.com" class="text-decoration-none">Make Bold Solutions</a> &middot;
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy</a>
                </span>
            </div>
        </div>
    </footer>

    <script src="~/js/vendors.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
