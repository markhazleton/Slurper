@model dynamic

@{
    string title = "—", id = "", sku = "", category = "", status = "", released = "", description = "";
    string monthly = "", annual = "";

    try { title = Model.name?.ToString() ?? Model.title?.ToString() ?? "—"; } catch { }
    try { id = Model.id?.ToString() ?? ""; } catch { }
    try { sku = Model.sku?.ToString() ?? ""; } catch { }
    try { category = Model.category?.ToString() ?? ""; } catch { }
    try { status = Model.status?.ToString() ?? ""; } catch { }
    try { released = Model.released?.ToString() ?? Model.publish_date?.ToString() ?? ""; } catch { }
    try { description = Model.description?.ToString() ?? ""; } catch { }
    try { monthly = Model.pricing?.monthly?.ToString() ?? Model.monthly_price?.ToString() ?? ""; } catch {
        try { monthly = Model.monthly_price?.ToString() ?? ""; } catch { }
    }
    try { annual = Model.pricing?.annual?.ToString() ?? Model.annual_price?.ToString() ?? ""; } catch {
        try { annual = Model.annual_price?.ToString() ?? ""; } catch { }
    }
}

<div class="card h-100 border-0 shadow-sm">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold">@title</h6>
        @if (!string.IsNullOrEmpty(status))
        {
            <span class="badge @(status == "active" ? "bg-success" : "bg-warning text-dark")">@status</span>
        }
    </div>
    <div class="card-body small">
        <dl class="row mb-0">
            @if (!string.IsNullOrEmpty(id))
            {
                <dt class="col-5 text-muted fw-normal">ID</dt>
                <dd class="col-7 mb-1"><code>@id</code></dd>
            }
            @if (!string.IsNullOrEmpty(sku))
            {
                <dt class="col-5 text-muted fw-normal">SKU</dt>
                <dd class="col-7 mb-1"><code>@sku</code></dd>
            }
            @if (!string.IsNullOrEmpty(category))
            {
                <dt class="col-5 text-muted fw-normal">Category</dt>
                <dd class="col-7 mb-1">@category</dd>
            }
            @if (!string.IsNullOrEmpty(monthly))
            {
                <dt class="col-5 text-muted fw-normal">Monthly</dt>
                <dd class="col-7 mb-1">$@monthly</dd>
            }
            @if (!string.IsNullOrEmpty(annual))
            {
                <dt class="col-5 text-muted fw-normal">Annual</dt>
                <dd class="col-7 mb-1">$@annual</dd>
            }
            @if (!string.IsNullOrEmpty(released))
            {
                <dt class="col-5 text-muted fw-normal">Released</dt>
                <dd class="col-7 mb-1">@released</dd>
            }
        </dl>
        @if (!string.IsNullOrEmpty(description))
        {
            <p class="text-muted mt-2 mb-0">@description</p>
        }
    </div>
</div>
