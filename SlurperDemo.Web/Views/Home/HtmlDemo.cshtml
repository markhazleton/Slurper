@{
    ViewData["Title"] = "HTML Extraction — WebSpark.Slurper";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Overview</a></li>
        <li class="breadcrumb-item active">HTML Extraction</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-3 gap-2">
    <span class="badge bg-warning text-dark fs-6">HTML</span>
    <h1 class="h3 mb-0 fw-bold">HTML Extraction</h1>
    <code class="ms-auto small text-muted">IHtmlExtractor.ExtractFromFile()</code>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-light">
                <h6 class="mb-0 fw-semibold">How it works</h6>
            </div>
            <div class="card-body small">
                <p class="mb-2">
                    The HTML extractor parses an HTML document into the same dynamic object model used
                    by XML extraction. Tags become properties, and nested tags become nested objects.
                    This is useful for scraping structured HTML that lacks a dedicated API.
                </p>
                <div class="bg-dark rounded p-2">
                    <pre class="mb-0 text-light" style="font-size:0.82em; line-height:1.6;"><code><span style="color:#569CD6;">var</span> pages = _htmlExtractor.<span style="color:#DCDCAA;">ExtractFromFile</span>(<span style="color:#CE9178;">"products.html"</span>);
<span style="color:#569CD6;">dynamic</span> root = pages.<span style="color:#DCDCAA;">First</span>();
<span style="color:#6A9955;">// Navigate the DOM as a property graph</span>
<span style="color:#569CD6;">var</span> body = root.html.body;
<span style="color:#6A9955;">// Repeated &lt;div&gt; elements → divList</span>
<span style="color:#569CD6;">foreach</span> (<span style="color:#569CD6;">var</span> div <span style="color:#569CD6;">in</span> body.div.divList)
{
    Console.<span style="color:#DCDCAA;">WriteLine</span>(div.h2);  <span style="color:#6A9955;">// product name</span>
}</code></pre>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-light">
                <h6 class="mb-0 fw-semibold">Source file <small class="text-muted fw-normal">wwwroot/data/products.html</small></h6>
            </div>
            <div class="card-body p-0">
                @if (ViewBag.RawHtmlContent != null)
                {
                    <details>
                        <summary class="btn btn-link btn-sm m-2">Show / Hide Raw HTML</summary>
                        <pre class="bg-dark text-light p-3 m-0 rounded-bottom"
                             style="font-size:0.78em; max-height:280px; overflow-y:auto;"><code>@ViewBag.RawHtmlContent</code></pre>
                    </details>
                }
                else
                {
                    <p class="text-muted small p-3 mb-0">Source file not available.</p>
                }
            </div>
        </div>
    </div>
</div>

@if (ViewBag.AvailableKeys != null)
{
    <div class="alert alert-info py-2 small mb-3">
        <strong>Top-level properties extracted:</strong> <code>@ViewBag.AvailableKeys</code>
    </div>
}

@if (ViewBag.Success == true)
{
    <div class="alert alert-success d-flex align-items-center gap-2 py-2">
        <i class="bi bi-check-circle-fill"></i>
        <span>@ViewBag.Message</span>
    </div>

    <h2 class="h5 fw-semibold mb-3">Extracted Records</h2>
    <div class="row g-3">
        @foreach (var book in ViewBag.BookList)
        {
            <div class="col-md-6 col-lg-4">
                <partial name="_BookDisplay" model="book" />
            </div>
        }
    </div>
}
else if (ViewBag.Success == false)
{
    <div class="alert alert-warning">
        <strong>Note:</strong> @ViewBag.Message
    </div>

    @if (ViewBag.CompleteStructure != null)
    {
        <div class="card">
            <div class="card-header bg-light">
                <h6 class="mb-0 fw-semibold">Raw extracted object structure (debug)</h6>
            </div>
            <div class="card-body p-0">
                <pre class="bg-dark text-light p-3 m-0 rounded-bottom"
                     style="font-size:0.78em; max-height:400px; overflow-y:auto;"><code>@ViewBag.CompleteStructure</code></pre>
            </div>
        </div>
    }
}

<div class="mt-4 d-flex gap-2 flex-wrap">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Overview</a>
    <a asp-action="LegacyDemo" class="btn btn-outline-secondary btn-sm">Next: Legacy Static API</a>
</div>
