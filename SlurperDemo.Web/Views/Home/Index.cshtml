@{
    ViewData["Title"] = "WebSpark.Slurper — Zero-Config Data Extraction for .NET";
}

<div class="row mb-4">
    <div class="col-lg-8">
        <h1 class="h2 fw-bold">WebSpark.Slurper</h1>
        <p class="lead text-muted mb-3">
            Zero-configuration data extraction from XML, JSON, CSV, and HTML into dynamic C# objects.
            No model classes. No boilerplate. Just dot-notation property access.
        </p>
        <div class="d-flex flex-wrap gap-2 mb-3">
            <a href="https://www.nuget.org/packages/WebSpark.Slurper" target="_blank" rel="noopener" class="btn btn-primary btn-sm">
                <i class="bi bi-box-seam me-1"></i>NuGet Package
            </a>
            <a href="https://github.com/MarkHazleton/Slurper" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-github me-1"></i>Source on GitHub
            </a>
        </div>
        <div class="bg-dark rounded p-3">
            <pre class="mb-0 text-light" style="font-size:0.85em; line-height:1.6;"><code><span style="color:#6A9955;">// Install</span>
dotnet add package WebSpark.Slurper

<span style="color:#6A9955;">// In Program.cs</span>
<span style="color:#4FC1FF;">builder</span>.<span style="color:#DCDCAA;">Services</span>.<span style="color:#DCDCAA;">AddSlurper</span>();

<span style="color:#6A9955;">// In your controller or service</span>
<span style="color:#569CD6;">var</span> result = _xmlExtractor.<span style="color:#DCDCAA;">ExtractFromFile</span>(<span style="color:#CE9178;">"catalog.xml"</span>);
<span style="color:#569CD6;">dynamic</span> first = result.<span style="color:#DCDCAA;">First</span>();
Console.<span style="color:#DCDCAA;">WriteLine</span>(first.product.name);   <span style="color:#6A9955;">// no class declaration needed</span></code></pre>
        </div>
    </div>
    <div class="col-lg-4 mt-3 mt-lg-0">
        <div class="card h-100 border-0 bg-light">
            <div class="card-body">
                <h6 class="text-uppercase text-muted fw-semibold mb-3 small">Key capabilities</h6>
                <ul class="list-unstyled mb-0 small">
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>XML, JSON, CSV &amp; HTML sources</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Dynamic property access — no POCO required</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Unified extractor interface across all formats</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Async + streaming for large files</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Full .NET DI container integration</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Plugin system for custom formats</li>
                    <li class="mb-0"><i class="bi bi-check-circle-fill text-success me-2"></i>Targets .NET 8, 9 &amp; 10</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<hr class="my-4" />

<h2 class="h5 fw-semibold mb-3">Live Extraction Demos</h2>
<div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-4">
        <a asp-action="XmlDemo" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm demo-card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-primary me-2">XML</span>
                        <small class="text-muted">IXmlExtractor</small>
                    </div>
                    <h6 class="card-title fw-semibold text-dark">XML Extraction</h6>
                    <p class="card-text small text-muted mb-0">
                        Parse a structured XML catalog. Inspect the raw source, then see how Slurper maps elements to navigable dynamic properties.
                    </p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a asp-controller="JSON" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm demo-card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-success me-2">JSON</span>
                        <small class="text-muted">IJsonExtractor</small>
                    </div>
                    <h6 class="card-title fw-semibold text-dark">JSON Extraction</h6>
                    <p class="card-text small text-muted mb-0">
                        Side-by-side comparison: raw JSON vs. Slurper extraction. Includes a code diff showing manual deserialization vs. Slurper.
                    </p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a asp-action="CsvDemo" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm demo-card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-info me-2">CSV</span>
                        <small class="text-muted">ICsvExtractor</small>
                    </div>
                    <h6 class="card-title fw-semibold text-dark">CSV Extraction</h6>
                    <p class="card-text small text-muted mb-0">
                        Extract tabular data from a CSV file. Column headers become property names with no configuration.
                    </p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a asp-action="HtmlDemo" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm demo-card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-warning text-dark me-2">HTML</span>
                        <small class="text-muted">IHtmlExtractor</small>
                    </div>
                    <h6 class="card-title fw-semibold text-dark">HTML Extraction</h6>
                    <p class="card-text small text-muted mb-0">
                        Traverse an HTML document's DOM tree as a dynamic object graph. No CSS selectors or XPath required.
                    </p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a asp-controller="ApiDemo" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm demo-card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-danger me-2">Multi</span>
                        <small class="text-muted">All extractors</small>
                    </div>
                    <h6 class="card-title fw-semibold text-dark">Multi-Format Demo</h6>
                    <p class="card-text small text-muted mb-0">
                        The same product catalog loaded simultaneously from JSON, XML, and CSV. Compare field access patterns across formats.
                    </p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a asp-action="LegacyDemo" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm demo-card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-secondary me-2">Legacy</span>
                        <small class="text-muted">Static API</small>
                    </div>
                    <h6 class="card-title fw-semibold text-dark">Legacy Static API</h6>
                    <p class="card-text small text-muted mb-0">
                        Demonstrates the pre-3.x <code>XmlSlurper.ParseFile()</code> and <code>JsonSlurper.ParseFile()</code> static methods, still supported for backward compatibility.
                    </p>
                </div>
            </div>
        </a>
    </div>
</div>

<hr class="my-4" />

<div class="row g-4">
    <div class="col-md-6">
        <h2 class="h5 fw-semibold mb-3">Array Handling</h2>
        <p class="small text-muted mb-2">
            When Slurper encounters a repeated element or JSON array, it generates a list property named
            <code>&lt;element&gt;List</code> by default. The suffix is configurable.
        </p>
        <div class="bg-dark rounded p-3">
            <pre class="mb-0 text-light" style="font-size:0.82em; line-height:1.6;"><code><span style="color:#6A9955;">// XML with repeated &lt;product&gt; elements</span>
<span style="color:#569CD6;">var</span> catalog = _xmlExtractor.<span style="color:#DCDCAA;">ExtractFromFile</span>(<span style="color:#CE9178;">"catalog.xml"</span>).<span style="color:#DCDCAA;">First</span>();
<span style="color:#569CD6;">foreach</span> (<span style="color:#569CD6;">var</span> p <span style="color:#569CD6;">in</span> catalog.productList)
{
    Console.<span style="color:#DCDCAA;">WriteLine</span>($<span style="color:#CE9178;">"{p.id}: {p.name} — ${p.pricing.monthly}/mo"</span>);
}</code></pre>
        </div>
    </div>
    <div class="col-md-6">
        <h2 class="h5 fw-semibold mb-3">Dependency Injection</h2>
        <p class="small text-muted mb-2">
            Register all extractors in one call, then inject the interface you need into controllers or services.
        </p>
        <div class="bg-dark rounded p-3">
            <pre class="mb-0 text-light" style="font-size:0.82em; line-height:1.6;"><code><span style="color:#6A9955;">// Program.cs</span>
<span style="color:#4FC1FF;">builder</span>.<span style="color:#DCDCAA;">Services</span>.<span style="color:#DCDCAA;">AddSlurper</span>();

<span style="color:#6A9955;">// Controller constructor</span>
<span style="color:#569CD6;">public</span> CatalogController(
    <span style="color:#4EC9B0;">IXmlExtractor</span> xml,
    <span style="color:#4EC9B0;">IJsonExtractor</span> json,
    <span style="color:#4EC9B0;">ICsvExtractor</span> csv,
    <span style="color:#4EC9B0;">IHtmlExtractor</span> html)
{ ... }</code></pre>
        </div>
    </div>
</div>

<style>
    .demo-card { transition: box-shadow 0.15s ease, transform 0.15s ease; }
    .demo-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.12) !important; transform: translateY(-2px); }
</style>
