@{
    ViewData["Title"] = "Multi-Format Demo — WebSpark.Slurper";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Overview</a></li>
        <li class="breadcrumb-item active">Multi-Format Demo</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-3 gap-2">
    <span class="badge bg-danger fs-6">Multi</span>
    <h1 class="h3 mb-0 fw-bold">Multi-Format Demo</h1>
    <small class="ms-auto text-muted">Same data extracted from JSON, XML, and CSV</small>
</div>

<p class="text-muted mb-4">
    This demo loads the identical product catalog from three different source formats simultaneously,
    demonstrating that Slurper's unified extractor interface produces consistent dynamic objects
    regardless of source format.
</p>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="display-6 mb-2"><i class="bi bi-braces text-success"></i></div>
                <h6 class="fw-semibold">JSON</h6>
                <p class="small text-muted mb-3">Nested structure with arrays and metadata</p>
                <code class="small text-muted d-block mb-3">productcatalog.products.productsList</code>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="display-6 mb-2"><i class="bi bi-file-code text-primary"></i></div>
                <h6 class="fw-semibold">XML</h6>
                <p class="small text-muted mb-3">Hierarchical elements with attributes</p>
                <code class="small text-muted d-block mb-3">root.productList</code>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="display-6 mb-2"><i class="bi bi-table text-info"></i></div>
                <h6 class="fw-semibold">CSV</h6>
                <p class="small text-muted mb-3">Flat tabular rows, header row as property names</p>
                <code class="small text-muted d-block mb-3">row.id, row.name, row.category</code>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-light">
                <h6 class="mb-0 fw-semibold">Extraction code (all three formats)</h6>
            </div>
            <div class="card-body p-0">
                <div class="bg-dark rounded-bottom p-3">
                    <pre class="mb-0 text-light" style="font-size:0.82em; line-height:1.6;"><code><span style="color:#6A9955;">// JSON — navigate nested path</span>
<span style="color:#569CD6;">var</span> json = _jsonExtractor.<span style="color:#DCDCAA;">ExtractFromFile</span>(<span style="color:#CE9178;">"ProductCatalog.json"</span>);
<span style="color:#569CD6;">dynamic</span> root = json.<span style="color:#DCDCAA;">First</span>();
<span style="color:#569CD6;">var</span> fromJson = root.productcatalog.products.productsList;

<span style="color:#6A9955;">// XML — top-level repeated elements</span>
<span style="color:#569CD6;">var</span> xml = _xmlExtractor.<span style="color:#DCDCAA;">ExtractFromFile</span>(<span style="color:#CE9178;">"ProductCatalog.xml"</span>);
<span style="color:#569CD6;">var</span> fromXml = xml.<span style="color:#DCDCAA;">First</span>().productList;

<span style="color:#6A9955;">// CSV — each row is a dynamic object</span>
<span style="color:#569CD6;">var</span> fromCsv = _csvExtractor.<span style="color:#DCDCAA;">ExtractFromFile</span>(<span style="color:#CE9178;">"products.csv"</span>);</code></pre>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-light">
                <h6 class="mb-0 fw-semibold">Product search <small class="text-muted fw-normal">(queries the JSON source)</small></h6>
            </div>
            <div class="card-body">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Search by name, SKU, category, or tag…" id="searchInput">
                    <button class="btn btn-primary" onclick="performSearch()">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                </div>
                <div id="searchResults" class="mt-3"></div>
            </div>
        </div>
    </div>
</div>

<div class="text-center">
    <a asp-action="ProductDatabase" class="btn btn-danger btn-lg">
        <i class="bi bi-layers me-2"></i>Run Multi-Format Extraction
    </a>
</div>

@section Scripts {
<script>
    function performSearch() {
        const term = document.getElementById('searchInput').value.trim();
        const results = document.getElementById('searchResults');
        if (!term) {
            results.innerHTML = '<div class="alert alert-warning py-2 small">Enter a search term.</div>';
            return;
        }
        results.innerHTML = '<div class="d-flex align-items-center gap-2 small text-muted"><div class="spinner-border spinner-border-sm"></div> Searching…</div>';
        fetch('/ApiDemo/ProductSearch', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'searchTerm=' + encodeURIComponent(term)
        })
        .then(r => r.json())
        .then(data => {
            if (!data.success) {
                results.innerHTML = '<div class="alert alert-danger py-2 small">' + data.message + '</div>';
                return;
            }
            if (data.count === 0) {
                results.innerHTML = '<div class="alert alert-info py-2 small">No products match <strong>' + term + '</strong>.</div>';
                return;
            }
            let html = '<div class="small text-muted mb-2">' + data.count + ' result(s) for <strong>' + term + '</strong></div>';
            html += '<div class="list-group list-group-flush">';
            data.products.forEach(p => {
                const statusBadge = p.status === 'active'
                    ? '<span class="badge bg-success ms-1">active</span>'
                    : '<span class="badge bg-warning text-dark ms-1">beta</span>';
                html += '<div class="list-group-item list-group-item-action px-0 py-2">';
                html += '<div class="d-flex align-items-center justify-content-between">';
                html += '<div><strong class="small">' + p.name + '</strong>' + statusBadge + '</div>';
                html += '<code class="small text-muted">' + p.sku + '</code>';
                html += '</div>';
                html += '<small class="text-muted">' + p.category + ' &middot; ' + p.id + '</small>';
                html += '</div>';
            });
            html += '</div>';
            results.innerHTML = html;
        })
        .catch(err => {
            results.innerHTML = '<div class="alert alert-danger py-2 small">Request failed: ' + err.message + '</div>';
        });
    }
    document.getElementById('searchInput').addEventListener('keydown', e => {
        if (e.key === 'Enter') performSearch();
    });
</script>
}
