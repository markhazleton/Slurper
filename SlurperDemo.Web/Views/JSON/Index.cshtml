@{
    ViewData["Title"] = "JSON Extraction — WebSpark.Slurper";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Overview</a></li>
        <li class="breadcrumb-item active">JSON Extraction</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-3 gap-2">
    <span class="badge bg-success fs-6">JSON</span>
    <h1 class="h3 mb-0 fw-bold">JSON Extraction</h1>
    <code class="ms-auto small text-muted">IJsonExtractor.ExtractFromFile()</code>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-semibold">Before: raw JSON source</h6>
                @if (!string.IsNullOrEmpty(ViewBag.MetadataVersion as string))
                {
                    <small class="text-muted">v@ViewBag.MetadataVersion &middot; @ViewBag.MetadataSource</small>
                }
            </div>
            <div class="card-body p-0">
                @if (ViewBag.FormattedJson != null)
                {
                    <details>
                        <summary class="btn btn-link btn-sm m-2">Show / Hide Raw JSON</summary>
                        <pre class="bg-dark text-light p-3 m-0 rounded-bottom"
                             style="font-size:0.78em; max-height:320px; overflow-y:auto;"><code>@ViewBag.FormattedJson</code></pre>
                    </details>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-light">
                <h6 class="mb-0 fw-semibold">How Slurper navigates the structure</h6>
            </div>
            <div class="card-body p-0">
                <div class="bg-dark rounded-bottom p-3">
                    <pre class="mb-0 text-light" style="font-size:0.82em; line-height:1.6;"><code><span style="color:#569CD6;">var</span> results = _jsonExtractor.<span style="color:#DCDCAA;">ExtractFromFile</span>(<span style="color:#CE9178;">"ProductCatalog.json"</span>);

<span style="color:#6A9955;">// Step 1 — get the root dynamic</span>
<span style="color:#569CD6;">dynamic</span> root = results.<span style="color:#DCDCAA;">First</span>();

<span style="color:#6A9955;">// Step 2 — underscores stripped: "product_catalog" → "productcatalog"</span>
<span style="color:#569CD6;">dynamic</span> catalog = root.productcatalog;

<span style="color:#6A9955;">// Step 3 — arrays become &lt;name&gt;List: "products" → productsList</span>
<span style="color:#569CD6;">var</span> list = catalog.products.productsList;

<span style="color:#6A9955;">// Step 4 — iterate, access nested pricing</span>
<span style="color:#569CD6;">foreach</span> (<span style="color:#569CD6;">var</span> p <span style="color:#569CD6;">in</span> list)
    Console.<span style="color:#DCDCAA;">WriteLine</span>($<span style="color:#CE9178;">"{p.id}: {p.name} ${p.pricing.monthly}/mo"</span>);</code></pre>
                </div>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.Success == true)
{
    <div class="mb-3">
        <div class="row g-2 mb-3">
            <div class="col-auto">
                <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-0">
                    <i class="bi bi-check-circle-fill"></i>
                    <span class="small">@ViewBag.Message</span>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card border-0 bg-light">
                    <div class="card-header bg-light border-0">
                        <h6 class="mb-0 fw-semibold">Manual approach (without Slurper)</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="bg-dark rounded-bottom p-3">
                            <pre class="mb-0 text-light" style="font-size:0.78em; line-height:1.6;"><code><span style="color:#6A9955;">// Must declare model classes up front</span>
<span style="color:#569CD6;">public record</span> ProductCatalog(
    <span style="color:#4EC9B0;">Metadata</span> Metadata,
    <span style="color:#4EC9B0;">Product</span>[] Products);

<span style="color:#569CD6;">public record</span> Product(
    <span style="color:#569CD6;">string</span> Id, <span style="color:#569CD6;">string</span> Sku, <span style="color:#569CD6;">string</span> Name,
    <span style="color:#4EC9B0;">Pricing</span> Pricing, <span style="color:#4EC9B0;">Specs</span> Specs, <span style="color:#4EC9B0;">string[]</span> Tags);

<span style="color:#6A9955;">// Then deserialize</span>
<span style="color:#569CD6;">var</span> options = <span style="color:#569CD6;">new</span> <span style="color:#4EC9B0;">JsonSerializerOptions</span>
    { PropertyNameCaseInsensitive = <span style="color:#569CD6;">true</span> };
<span style="color:#569CD6;">var</span> catalog = JsonSerializer.Deserialize
    &lt;<span style="color:#4EC9B0;">ProductCatalog</span>&gt;(json, options);</code></pre>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 bg-light">
                    <div class="card-header bg-light border-0">
                        <h6 class="mb-0 fw-semibold">With Slurper (no classes needed)</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="bg-dark rounded-bottom p-3">
                            <pre class="mb-0 text-light" style="font-size:0.78em; line-height:1.6;"><code><span style="color:#6A9955;">// Zero model classes — just extract and navigate</span>
<span style="color:#569CD6;">var</span> results = _jsonExtractor
    .<span style="color:#DCDCAA;">ExtractFromFile</span>(<span style="color:#CE9178;">"ProductCatalog.json"</span>);

<span style="color:#569CD6;">dynamic</span> first = results.<span style="color:#DCDCAA;">First</span>();
<span style="color:#569CD6;">var</span> list = first.productcatalog
                   .products.productsList;

<span style="color:#6A9955;">// Works with any JSON structure — no schema lock-in</span>
<span style="color:#569CD6;">foreach</span> (<span style="color:#569CD6;">var</span> p <span style="color:#569CD6;">in</span> list)
    <span style="color:#4EC9B0;">DoWork</span>(p.id, p.name, p.pricing.monthly);</code></pre>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <h2 class="h5 fw-semibold mb-3">Extracted records</h2>

        <div class="mb-3">
            <div class="row g-2 mb-2">
                @foreach (var step in ViewBag.ProcessingSteps)
                {
                    <div class="col-12">
                        <div class="d-flex align-items-start gap-2 small text-muted">
                            <i class="bi bi-arrow-right-short flex-shrink-0 mt-1"></i>
                            <span>@step</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="row g-3">
            @foreach (var product in ViewBag.ProductList)
            {
                <div class="col-md-6 col-lg-4">
                    @{
                        string name = "—", id = "", sku = "", category = "", status = "";
                        string monthly = "", annual = "", released = "";
                        try { name = product.name?.ToString() ?? "—"; } catch { }
                        try { id = product.id?.ToString() ?? ""; } catch { }
                        try { sku = product.sku?.ToString() ?? ""; } catch { }
                        try { category = product.category?.ToString() ?? ""; } catch { }
                        try { status = product.status?.ToString() ?? ""; } catch { }
                        try { monthly = product.pricing?.monthly?.ToString() ?? ""; } catch { }
                        try { annual = product.pricing?.annual?.ToString() ?? ""; } catch { }
                        try { released = product.released?.ToString() ?? ""; } catch { }
                    }
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h6 class="mb-0 fw-semibold small">@name</h6>
                            @if (!string.IsNullOrEmpty(status))
                            {
                                <span class="badge @(status == "active" ? "bg-success" : "bg-warning text-dark")">@status</span>
                            }
                        </div>
                        <div class="card-body small">
                            <dl class="row mb-0">
                                @if (!string.IsNullOrEmpty(id)) { <dt class="col-5 text-muted fw-normal">ID</dt><dd class="col-7 mb-1"><code>@id</code></dd> }
                                @if (!string.IsNullOrEmpty(sku)) { <dt class="col-5 text-muted fw-normal">SKU</dt><dd class="col-7 mb-1"><code>@sku</code></dd> }
                                @if (!string.IsNullOrEmpty(category)) { <dt class="col-5 text-muted fw-normal">Category</dt><dd class="col-7 mb-1">@category</dd> }
                                @if (!string.IsNullOrEmpty(monthly)) { <dt class="col-5 text-muted fw-normal">Monthly</dt><dd class="col-7 mb-1">$@monthly</dd> }
                                @if (!string.IsNullOrEmpty(annual)) { <dt class="col-5 text-muted fw-normal">Annual</dt><dd class="col-7 mb-1">$@annual</dd> }
                                @if (!string.IsNullOrEmpty(released)) { <dt class="col-5 text-muted fw-normal">Released</dt><dd class="col-7 mb-0">@released</dd> }
                            </dl>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-danger">
        <strong>Extraction error:</strong> @ViewBag.Message
    </div>
}

<div class="mt-4 d-flex gap-2 flex-wrap">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Overview</a>
    <a asp-controller="Home" asp-action="CsvDemo" class="btn btn-outline-info btn-sm">Next: CSV Extraction</a>
</div>
